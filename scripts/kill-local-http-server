#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 <pid>" >&2
}

if [[ $# -ne 1 ]]; then
  usage
  exit 2
fi

pid="$1"
if [[ ! "$pid" =~ ^[0-9]+$ ]]; then
  echo "error: pid must be numeric" >&2
  usage
  exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

if ! kill -0 "$pid" 2>/dev/null; then
  echo "error: no process with pid $pid" >&2
  exit 1
fi

command_line="$(ps -p "$pid" -o command= 2>/dev/null || true)"
if [[ -z "$command_line" ]]; then
  echo "error: could not inspect pid $pid" >&2
  exit 1
fi

if [[ ! "$command_line" =~ (^|[[:space:]/])python([0-9.]+)?[[:space:]]+-m[[:space:]]+http[.]server([[:space:]]|$) ]]; then
  echo "error: pid $pid is not a python -m http.server process" >&2
  echo "command: $command_line" >&2
  exit 1
fi

cwd="$(lsof -a -p "$pid" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -n 1)"
if [[ -z "$cwd" ]]; then
  echo "error: could not inspect working directory for pid $pid" >&2
  exit 1
fi

process_cwd="$(cd "$cwd" && pwd -P)"
case "$process_cwd" in
  "$repo_root"|"$repo_root"/*)
    ;;
  *)
    echo "error: refusing to kill pid $pid outside this repo" >&2
    echo "cwd: $process_cwd" >&2
    echo "repo: $repo_root" >&2
    exit 1
    ;;
esac

kill "$pid"
